# Client (public)
EXPO_PUBLIC_CLOUD_PROJECT_NUMBER=""
# Public URL of the deployed Node server running the API routes. Required for
# device/production builds (relative requests only resolve to the dev server).
EXPO_PUBLIC_API_URL=""

# Build-time — iOS App Attest entitlement (production | development).
APP_ATTEST_ENVIRONMENT="production"

# Google Play Integrity (server) — path to the service account JSON.
GOOGLE_APPLICATION_CREDENTIALS=""
GOOGLE_PLAY_APP_PACKAGE_NAME="com.chitrakshtarun.appintegrity"

# Apple App Attest (server).
IOS_BUNDLE_IDENTIFIER="com.chitrakshtarun.appintegrity"
IOS_TEAM_IDENTIFIER=""
# Set "true" only when APP_ATTEST_ENVIRONMENT=development.
IOS_ALLOW_DEVELOPMENT_ENVIRONMENT=""
